# Development only variables (changes on prod)
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CONVEX_SITE_URL=
CLERK_JWT_ISSUER_URL=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
# Dev and prod variables (unchanging)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/
REDIS_URL=
LANDING_METRICS_API_KEY=
LANDING_METRICS_REQUIRE_API_KEY=false

# OAuth (ChatGPT App)
# Optional static client credentials (if omitted, dynamic client registration is used)
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_JWT_SECRET=
# Optional; defaults to OAUTH_RESOURCE
OAUTH_AUDIENCE=
# Canonical protected resource identifier (optional; defaults to OAUTH_ISSUER)
OAUTH_RESOURCE=
OAUTH_ALLOWED_REDIRECT_URIS=https://chatgpt.com/connector_platform_oauth_redirect,https://platform.openai.com/apps-manage/oauth
# Required in production: canonical HTTPS app origin used for OAuth discovery + widget metadata
# Preview example: https://stats-dev.cleoai.cloud
# Production example: https://stats.cleoai.cloud
OAUTH_ISSUER=
# Optional; comma-separated allowlist
OAUTH_ALLOWED_SCOPES=
# Optional documentation URL published in protected resource metadata
OAUTH_RESOURCE_DOCUMENTATION=

# Public URL to open your ChatGPT app for user-initiated OAuth linking
# Example: https://chatgpt.com/g/g-xxxxxxxxxxxxxxxxxxxx-your-app-name
NEXT_PUBLIC_CHATGPT_APP_CONNECT_URL=
