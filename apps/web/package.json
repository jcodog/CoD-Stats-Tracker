{
  "name": "web",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "bun run --cwd ../.. coverage:prepare && next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "bun run test:env && bun run test:api && bun run test:debug && bun run test:oauth && bun run test:mcp",
    "test:env": "bun test \"lib/server/__tests__/app-public-origin.test.mjs\" \"lib/server/__tests__/server-env.test.mjs\"",
    "test:api": "bun test \"app/api/(chatgpt-app-connector)/app/__tests__/routes.test.mjs\"",
    "test:debug": "bun test \"app/(chatgpt-app-connector)/debug/__tests__/chatgpt-app-config.test.mjs\"",
    "test:mcp": "bun test \"lib/server/__tests__/chatgpt-app-mcp.test.mjs\"",
    "test:oauth": "bun test \"app/(chatgpt-app-connector)/oauth/__tests__\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.2.1",
    "@clerk/themes": "^2.4.57",
    "@databuddy/sdk": "^2.4.0",
    "@flags-sdk/vercel": "^1.3.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@stripe/react-stripe-js": "^6.2.0",
    "@stripe/stripe-js": "^9.2.0",
    "@tabler/icons-react": "^3.41.1",
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-table": "^8.21.3",
    "@workspace/backend": "workspace:*",
    "@workspace/ui": "workspace:*",
    "convex": "^1.35.1",
    "flags": "^4.0.6",
    "next": "16.2.4",
    "next-themes": "^0.4.6",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "recharts": "3.8.1",
    "sonner": "^2.0.7",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@workspace/eslint-config": "workspace:^",
    "@workspace/typescript-config": "workspace:*",
    "eslint": "^10.2.0",
    "typescript": "^6.0.2"
  }
}
