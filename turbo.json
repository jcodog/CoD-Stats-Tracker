{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalEnv": [
    "APP_PUBLIC_ORIGIN",
    "CLERK_JWT_ISSUER_URL",
    "CLERK_SECRET_KEY",
    "CLERK_WEBHOOK_SECRET",
    "CONVEX_DEPLOYMENT",
    "DISCORD_APPLICATION_ID",
    "DISCORD_APPLICATION_PUBLIC_KEY",
    "DISCORD_BOT_TOKEN",
    "DISCORD_DEV_GUILD_ID",
    "LANDING_METRICS_API_KEY",
    "LANDING_METRICS_REQUIRE_API_KEY",
    "KV_URL",
    "NEXT_PUBLIC_*",
    "NODE_ENV",
    "OAUTH_*",
    "REDIS_URL",
    "REDIS_TLS_URL",
    "STRIPE_SECRET_KEY",
    "STRIPE_WEBHOOK_SECRET",
    "SUPER_ADMIN_DISCORD_ID",
    "SUPER_ADMIN_DISCORD_IDS",
    "VERCEL",
    "VERCEL_ACCESS_TOKEN",
    "VERCEL_*",
    "VERCEL_PROJECT_ID_OR_NAME",
    "VERCEL_TEAM_ID",
    "FLAGS",
    "FLAGS_SECRET"
  ],
  "tasks": {
    "codegen": {
      "env": [
        "CLERK_JWT_ISSUER_URL",
        "CLERK_SECRET_KEY",
        "CLERK_WEBHOOK_SECRET",
        "CONVEX_DEPLOYMENT",
        "DISCORD_APPLICATION_ID",
        "DISCORD_APPLICATION_PUBLIC_KEY",
        "DISCORD_BOT_TOKEN",
        "DISCORD_DEV_GUILD_ID",
        "KV_URL",
        "NODE_ENV",
        "REDIS_URL",
        "REDIS_TLS_URL",
        "STRIPE_SECRET_KEY",
        "STRIPE_WEBHOOK_SECRET",
        "SUPER_ADMIN_DISCORD_ID",
        "SUPER_ADMIN_DISCORD_IDS",
        "VERCEL_ACCESS_TOKEN",
        "VERCEL_PROJECT_ID_OR_NAME",
        "VERCEL_TEAM_ID"
      ],
      "dependsOn": ["^codegen"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"]
    },
    "deploy": {
      "env": [
        "CLERK_JWT_ISSUER_URL",
        "CLERK_SECRET_KEY",
        "CLERK_WEBHOOK_SECRET",
        "CONVEX_DEPLOYMENT",
        "DISCORD_APPLICATION_ID",
        "DISCORD_APPLICATION_PUBLIC_KEY",
        "DISCORD_BOT_TOKEN",
        "DISCORD_DEV_GUILD_ID",
        "KV_URL",
        "NODE_ENV",
        "REDIS_URL",
        "REDIS_TLS_URL",
        "STRIPE_SECRET_KEY",
        "STRIPE_WEBHOOK_SECRET",
        "SUPER_ADMIN_DISCORD_ID",
        "SUPER_ADMIN_DISCORD_IDS",
        "VERCEL_ACCESS_TOKEN",
        "VERCEL_PROJECT_ID_OR_NAME",
        "VERCEL_TEAM_ID"
      ],
      "dependsOn": ["^deploy"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "env": [
        "APP_PUBLIC_ORIGIN",
        "CLERK_JWT_ISSUER_URL",
        "CLERK_SECRET_KEY",
        "CLERK_WEBHOOK_SECRET",
        "CONVEX_DEPLOYMENT",
        "DISCORD_APPLICATION_ID",
        "DISCORD_APPLICATION_PUBLIC_KEY",
        "DISCORD_BOT_TOKEN",
        "DISCORD_DEV_GUILD_ID",
        "LANDING_METRICS_API_KEY",
        "LANDING_METRICS_REQUIRE_API_KEY",
        "KV_URL",
        "NEXT_PUBLIC_*",
        "NODE_ENV",
        "OAUTH_*",
        "REDIS_URL",
        "REDIS_TLS_URL",
        "STRIPE_SECRET_KEY",
        "STRIPE_WEBHOOK_SECRET",
        "SUPER_ADMIN_DISCORD_ID",
        "SUPER_ADMIN_DISCORD_IDS",
        "VERCEL",
        "VERCEL_ACCESS_TOKEN",
        "VERCEL_*",
        "VERCEL_PROJECT_ID_OR_NAME",
        "VERCEL_TEAM_ID",
        "FLAGS",
        "FLAGS_SECRET"
      ]
    },
    "build": {
      "env": [
        "APP_PUBLIC_ORIGIN",
        "CLERK_SECRET_KEY",
        "LANDING_METRICS_API_KEY",
        "LANDING_METRICS_REQUIRE_API_KEY",
        "KV_URL",
        "NEXT_PUBLIC_*",
        "NODE_ENV",
        "OAUTH_*",
        "REDIS_URL",
        "REDIS_TLS_URL",
        "FLAGS",
        "FLAGS_SECRET"
      ],
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "format": {
      "dependsOn": ["^format"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    }
  }
}
