{
  "name": "cod-stats",
  "version": "0.1.0",
  "devDependencies": {
    "@t3-oss/env-core": "^0.13.11",
    "@t3-oss/env-nextjs": "^0.13.11",
    "@typescript/native-preview": "^7.0.0-dev.20260416.1",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.9.6",
    "typescript": "6.0.2"
  },
  "engines": {
    "node": ">=20"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "packageManager": "bun@1.3.12",
  "private": true,
  "scripts": {
    "deps:update": "bunx npm-check-updates@latest -u \"/.*/\" -ws && bun install",
    "build": "turbo build",
    "coverage": "bun run coverage:clean && bun run coverage:collect && bun run coverage:build-report",
    "coverage:build-report": "node scripts/coverage/build-report.mjs",
    "coverage:clean": "node scripts/coverage/clean.mjs",
    "coverage:collect": "bun test --coverage --coverage-reporter=text --coverage-reporter=lcov --coverage-dir .coverage apps/web/app apps/web/lib packages/backend/convex packages/backend/src",
    "coverage:prepare": "node scripts/coverage/prepare.mjs",
    "convex:codegen": "turbo run codegen --filter=@workspace/backend",
    "convex:dev": "turbo run dev --filter=@workspace/backend",
    "convex:deploy": "turbo run deploy --filter=@workspace/backend",
    "dev": "turbo run dev",
    "format": "turbo run format",
    "lint": "turbo run lint",
    "test": "bun run test:web && bun run test:backend",
    "test:app": "bun run --cwd apps/web test",
    "test:app:api": "bun run --cwd apps/web test:api",
    "test:app:debug": "bun run --cwd apps/web test:debug",
    "test:backend:env": "bun test \"packages/backend/convex/__tests__/env.test.mjs\"",
    "test:backend": "bun run --cwd packages/backend test",
    "test:app:mcp": "bun run --cwd apps/web test:mcp",
    "test:app:oauth": "bun run --cwd apps/web test:oauth",
    "test:app:smoke": "node scripts/chatgpt-app-smoke.mjs",
    "test:web": "bun run --cwd apps/web test",
    "typecheck": "turbo run typecheck",
    "verify:chatgpt-app": "node scripts/verify-chatgpt-app.mjs"
  },
  "trustedDependencies": [
    "esbuild",
    "msw",
    "sharp",
    "unrs-resolver"
  ],
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "minimatch": "^10.2.5",
    "playwright": "^1.59.1"
  }
}
