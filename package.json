{
  "name": "cod-stats",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.10",
  "scripts": {
    "build": "turbo build",
    "convex:codegen": "turbo run convex:codegen",
    "convex:dev": "turbo run convex:dev",
    "convex:deploy": "turbo run convex:deploy",
    "dev": "turbo run dev",
    "format": "turbo run format",
    "lint": "turbo run lint",
    "test:app": "bun run --cwd apps/web test",
    "test:app:api": "bun run --cwd apps/web test:api",
    "test:app:debug": "bun run --cwd apps/web test:debug",
    "test:app:mcp": "bun run --cwd apps/web test:mcp",
    "test:app:oauth": "bun run --cwd apps/web test:oauth",
    "test:app:smoke": "node scripts/chatgpt-app-smoke.mjs",
    "typecheck": "turbo run typecheck",
    "verify:chatgpt-app": "node scripts/verify-chatgpt-app.mjs"
  },
  "devDependencies": {
    "@typescript/native-preview": "^7.0.0-dev.20260301.1",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.8.8",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=20"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "esbuild",
    "msw",
    "sharp",
    "unrs-resolver"
  ],
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
