{
  "name": "@workspace/backend",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "codegen": "convex codegen",
    "dev": "convex dev",
    "deploy": "convex deploy -y",
    "lint": "eslint .",
    "migrate:disable-viewer-queue-twitch": "convex run actions/migrations/playingWithViewers:runViewerQueueTwitchDisableMigration '{\"confirm\":\"disable_viewer_queue_twitch_integration\"}'",
    "migrate:disable-viewer-queue-twitch:dry": "convex run actions/migrations/playingWithViewers:runViewerQueueTwitchDisableMigration '{\"confirm\":\"disable_viewer_queue_twitch_integration\",\"dryRun\":true}'",
    "migrate:viewer-queue-schema": "convex run actions/migrations/playingWithViewers:runLegacyViewerQueueSchemaMigration '{\"confirm\":\"migrate_legacy_viewer_queue_schema\"}'",
    "migrate:viewer-queue-schema:dry": "convex run actions/migrations/playingWithViewers:runLegacyViewerQueueSchemaMigration '{\"confirm\":\"migrate_legacy_viewer_queue_schema\",\"dryRun\":true}'",
    "migrate:viewer-queue-invite-mode": "convex run actions/migrations/playingWithViewers:runViewerQueueInviteModeMigration '{\"confirm\":\"migrate_viewer_queue_invite_modes\"}'",
    "migrate:viewer-queue-invite-mode:dry": "convex run actions/migrations/playingWithViewers:runViewerQueueInviteModeMigration '{\"confirm\":\"migrate_viewer_queue_invite_modes\",\"dryRun\":true}'",
    "test": "bun run test:env && bun run test:server && bun run test:convex",
    "test:convex": "bun test \"convex/__tests__\" \"lib/__tests__\" \"convex/mutations/__tests__\"",
    "test:env": "bun test \"convex/__tests__/env.test.mjs\"",
    "test:server": "bun test \"src/server/__tests__\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clerk/backend": "^3.4.1",
    "@clerk/nextjs": "^7.2.7",
    "@modelcontextprotocol/ext-apps": "^1.7.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "convex": "^1.36.1",
    "discord-api-types": "^0.38.47",
    "next": "16.2.4",
    "redis": "^5.12.1",
    "stripe": "^22.1.0",
    "svix": "^1.92.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "eslint": "^10.2.1",
    "typescript": "^6.0.3"
  },
  "exports": {
    "./lib/*": "./lib/*.ts",
    "./convex/*": "./convex/*",
    "./landing/*": "./src/landing/*.ts",
    "./server/*": "./src/server/*.ts"
  }
}
