{
  "name": "@workspace/backend",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "codegen": "convex codegen",
    "dev": "convex dev",
    "deploy": "convex deploy -y",
    "lint": "eslint .",
    "test": "bun run test:env && bun run test:server && bun run test:convex",
    "test:convex": "bun test \"convex/__tests__\" \"convex/lib/__tests__\" \"convex/mutations/__tests__\"",
    "test:env": "bun test \"convex/__tests__/env.test.mjs\"",
    "test:server": "bun test \"src/server/__tests__\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clerk/backend": "^3.2.4",
    "@clerk/nextjs": "^7.0.8",
    "@modelcontextprotocol/ext-apps": "^1.5.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "convex": "^1.34.1",
    "discord-api-types": "^0.38.44",
    "next": "16.2.2",
    "redis": "^5.11.0",
    "stripe": "^22.0.0",
    "svix": "^1.90.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "eslint": "^10.1.0",
    "typescript": "^6.0.2"
  },
  "exports": {
    "./lib/*": "./convex/lib/*.ts",
    "./convex/*": "./convex/*",
    "./landing/*": "./src/landing/*.ts",
    "./server/*": "./src/server/*.ts"
  }
}
