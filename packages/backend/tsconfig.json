{
  "extends": "@workspace/typescript-config/base.json",
  "compilerOptions": {
    "allowJs": true,
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noUncheckedIndexedAccess": false,
    "noEmit": true,
    "paths": {
      "@workspace/backend/lib/*": ["./convex/lib/*"],
      "@workspace/backend/convex/*": ["./convex/*"],
      "@workspace/backend/landing/*": ["./src/landing/*"],
      "@workspace/backend/server/*": ["./src/server/*"]
    }
  },
  "include": ["src/**/*", "convex/**/*"],
  "exclude": ["node_modules"]
}
